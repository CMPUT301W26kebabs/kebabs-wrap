<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EventManager"
        tools:targetApi="31">

        <!-- Fahad's Sign Up is the FIRST screen -->
        <activity android:name=".ui.EntrantSignUpActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Fahad's onboarding flow -->
        <activity android:name=".ui.BookedEventsActivity" android:exported="false" />
        <activity android:name=".ui.QrAccessActivity" android:exported="false" />

        <!-- Admin Dashboard (Ibrahim) -->
        <activity android:name=".MainActivity" android:exported="false" />

        <!-- Huzaifa's activities -->
        <activity android:name=".CreateEventActivity" android:exported="false" />
        <activity android:name=".ManagePosterActivity" android:exported="false" />
        <activity android:name=".EventQRActivity" android:exported="false" />
        <activity android:name=".MyEventsActivity" android:exported="false" />

        <!-- Umar's activities -->
        <activity android:name=".EnrolledListActivity" android:exported="false" />
        <activity android:name=".RunLotteryActivity" android:exported="false" />

        <!-- Ibrahim's admin screens -->
        <activity android:name=".admin.AdminEventsActivity" android:exported="false" android:theme="@style/Theme.AppCompat.Light.NoActionBar" />
        <activity android:name=".admin.AdminProfilesActivity" android:exported="false" android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

    </application>
</manifest>
