    </item>
    <item
        android:bottom="4dp"
        android:left="4dp"
        android:right="4dp"
        android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_accent" />
            <corners android:radius="1dp" />
        </shape>
    </item>
</layer-list>
