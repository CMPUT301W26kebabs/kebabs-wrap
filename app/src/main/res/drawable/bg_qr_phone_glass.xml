<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow / depth layer -->
    <item
        android:bottom="-2dp"
        android:left="3dp"
        android:right="-3dp"
        android:top="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#12FFFFFF" />
            <corners android:radius="30dp" />
        </shape>
    </item>
    <!-- Phone body -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:endColor="#1E1754"
                android:startColor="#16123E" />
            <corners android:radius="30dp" />
            <stroke
                android:width="1dp"
                android:color="#30FFFFFF" />
        </shape>
    </item>
    <!-- Inner screen bezel highlight -->
    <item
        android:bottom="8dp"
        android:left="6dp"
        android:right="6dp"
        android:top="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#08FFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
