<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FA">

    <!-- ── Header ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#5C35D4"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Invitation"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="8dp" />

    </LinearLayout>

    <!-- ── Content Card ── -->
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:gravity="center">

            <!-- Trophy icon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎉"
                android:textSize="52sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You've been selected!"
                android:textColor="#1A1A2E"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You were chosen to attend:"
                android:textColor="#757575"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginBottom="4dp" />

            <!-- Event name — populated by AcceptDeclineActivity -->
            <TextView
                android:id="@+id/text_event_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#5C35D4"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="32dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Would you like to accept this invitation?"
                android:textColor="#9E9E9E"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="28dp" />

            <!-- Accept Button -->
            <Button
                android:id="@+id/btn_accept"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Accept Invitation"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:backgroundTint="#5C35D4"
                android:layout_marginBottom="12dp" />

            <!-- Decline Button -->
            <Button
                android:id="@+id/btn_decline"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Decline"
                android:textColor="#5C35D4"
                android:textSize="16sp"
                android:backgroundTint="#EDE9FB" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>