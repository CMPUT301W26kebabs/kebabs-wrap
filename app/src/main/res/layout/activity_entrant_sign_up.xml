<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_signup_top_gradient"
    tools:context=".ui.EntrantSignUpActivity">

    <!-- Animated characters in the gradient area -->
    <com.example.eventmanager.ui.SignupCharactersView
        android:id="@+id/charactersView"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_gravity="top" />

    <!-- Decorative blurred circles in the gradient area -->
    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="-40dp"
        android:alpha="0.08"
        android:background="@drawable/bg_calendar_phone_glow" />

    <View
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-30dp"
        android:layout_marginTop="80dp"
        android:alpha="0.06"
        android:background="@drawable/bg_calendar_phone_glow" />

    <!-- Form area that scrolls and overlaps the characters -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Spacer to push the form card below the characters -->
            <View
                android:layout_width="match_parent"
                android:layout_height="240dp" />

            <!-- White form card with rounded top corners -->
            <LinearLayout
                android:id="@+id/formCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_signup_form_card"
                android:orientation="vertical"
                android:paddingStart="26dp"
                android:paddingTop="32dp"
                android:paddingEnd="26dp"
                android:paddingBottom="32dp">

                <TextView
                    android:id="@+id/signUpTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="@string/sign_up_title"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/signUpSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/sign_up_subtitle"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp" />

                <!-- Form fields -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:orientation="vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/nameInputLayout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/name_label"
                        app:boxBackgroundColor="@color/white"
                        app:boxCornerRadiusBottomEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusTopStart="14dp"
                        app:boxStrokeColor="@color/outline_lavender"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                        app:startIconTint="@color/text_muted">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/nameInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_muted" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/emailInputLayout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="@string/email_label"
                        app:boxBackgroundColor="@color/white"
                        app:boxCornerRadiusBottomEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusTopStart="14dp"
                        app:boxStrokeColor="@color/outline_lavender"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:startIconDrawable="@android:drawable/ic_dialog_email"
                        app:startIconTint="@color/text_muted">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/emailInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_muted" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/termsText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center"
                        android:text="@string/terms_copy"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/signUpButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:backgroundTint="@color/primary_purple"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:text="@string/sign_up_cta"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="14dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
