<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F3FA"
    android:paddingBottom="12dp">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/inviteGuestsToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F5F3FA"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:navigationIcon="@android:drawable/ic_media_previous"
        app:title="Search Guests"
        app:titleTextColor="#4B4BCB" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_search_box"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_menu_search"
            app:tint="#6F6A90" />

        <EditText
            android:id="@+id/searchGuestInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:background="@android:color/transparent"
            android:hint="Search by Name, Email, or Phone"
            android:textColor="#2E2C59"
            android:textColorHint="#7E789B" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="82dp"
            android:layout_height="wrap_content"
            android:text="Filter\nby:"
            android:textColor="#4A456A"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/nameFilterButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_filter_selected"
            android:text="Name"
            android:textAllCaps="false"
            android:textColor="#4B4BCB"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/emailFilterButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_filter_unselected"
            android:text="Email"
            android:textAllCaps="false"
            android:textColor="#5B577A"
            android:textSize="16sp" />

        <Button
            android:id="@+id/phoneFilterButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:background="@drawable/bg_filter_unselected"
            android:text="Phone"
            android:textAllCaps="false"
            android:textColor="#5B577A"
            android:textSize="16sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/guestsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:clipToPadding="false" />

</LinearLayout>