<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FF"
    tools:context=".organizer.LotteryDrawActivity">

    <!-- ===== BLUE HEADER BACKGROUND ===== -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:background="@drawable/bg_lottery_header" />

    <!-- ===== BACK ARROW + TITLE ===== -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Lottery Draw"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- ===== SCROLLABLE CONTENT ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingTop="160dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- ===== MAIN DRAW CARD ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDraw"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="20dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="32dp"
                    android:paddingBottom="32dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:gravity="center">

                    <!-- Illustration + Number of Winners Title Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Illustration Circle -->
                        <FrameLayout
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_marginEnd="16dp">

                            <View
                                android:layout_width="100dp"
                                android:layout_height="100dp"
                                android:background="@drawable/bg_illustration_circle" />

                            <!-- Decorative dots -->
                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:layout_gravity="top|end"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/dot_teal" />

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:layout_gravity="bottom|start"
                                android:layout_marginBottom="10dp"
                                android:background="@drawable/dot_red" />

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:layout_gravity="center_vertical|end"
                                android:background="@drawable/dot_green" />

                            <!-- Trophy / lottery icon in center -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="🎰"
                                android:textSize="38sp" />

                        </FrameLayout>

                        <!-- Title -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Number of Winners"
                            android:textColor="#1A1A2E"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="20dp"
                        android:background="#F0F0F5" />

                    <!-- Counter Row: MINUS — NUMBER — PLUS -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_gravity="center">

                        <!-- Minus Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDecrement"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:text="−"
                            android:textSize="26sp"
                            android:textColor="#FFFFFF"
                            app:backgroundTint="#5C6BC0"
                            app:cornerRadius="26dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            style="@style/Widget.MaterialComponents.Button" />

                        <!-- Number Display -->
                        <TextView
                            android:id="@+id/tvWinnerCount"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="10"
                            android:textColor="#1A1A2E"
                            android:textSize="48sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:fontFamily="sans-serif-black" />

                        <!-- Plus Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnIncrement"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:text="+"
                            android:textSize="26sp"
                            android:textColor="#FFFFFF"
                            app:backgroundTint="#5C6BC0"
                            app:cornerRadius="26dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            style="@style/Widget.MaterialComponents.Button" />

                    </LinearLayout>

                    <!-- "from X waiting entrants" label -->
                    <TextView
                        android:id="@+id/tvWaitlistCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="from 42 waiting entrants"
                        android:textColor="#8A8AA0"
                        android:textSize="13sp"
                        android:gravity="center" />

                    <!-- Progress bar for visual feedback -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressBarDraw"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="4dp"
                        android:visibility="gone"
                        app:indicatorColor="#5C6BC0"
                        app:trackColor="#E8EAFF"
                        app:trackCornerRadius="4dp"
                        style="@style/Widget.MaterialComponents.LinearProgressIndicator" />

                    <!-- DRAW WINNERS Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDrawWinners"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="20dp"
                        android:text="🎯  DRAW WINNERS"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        app:backgroundTint="#5C6BC0"
                        app:cornerRadius="28dp"
                        style="@style/Widget.MaterialComponents.Button" />

                    <!-- Error / status message -->
                    <TextView
                        android:id="@+id/tvStatusMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:visibility="gone"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:textColor="#E53935" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== DIVIDER WITH LABEL ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="28dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#DDE0F0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="Or draw replacement:"
                    android:textColor="#555577"
                    android:textSize="14sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#DDE0F0" />

            </LinearLayout>

            <!-- ===== DRAW REPLACEMENT BUTTON ===== -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDrawReplacement"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:minWidth="220dp"
                android:text="DRAW 1 REPLACEMENT"
                android:textColor="#3D3D6B"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#5C6BC0"
                app:strokeWidth="2dp"
                app:cornerRadius="26dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <!-- ===== RESULTS SECTION (shown after draw) ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="28dp"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Results Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🏆  Selected Winners"
                            android:textColor="#1A1A2E"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvResultCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_indigo"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Winner List RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvWinners"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>