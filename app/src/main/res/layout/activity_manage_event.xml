<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    >

    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:padding="12dp"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="#3F38DD"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_app_bar_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Event Manager"
        android:textColor="#3F38DD"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btn_back"
        app:layout_constraintStart_toEndOf="@+id/btn_back"
        app:layout_constraintTop_toTopOf="@+id/btn_back" />



    <TextView
        android:id="@+id/text_event_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="Tech\nMeetup\n2026"
        android:textColor="#2B2D42"
        android:textSize="40sp"
        android:textStyle="bold"
        android:lineSpacingExtra="-8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_back" />

    <LinearLayout
        android:id="@+id/layout_action_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="start"
        app:layout_constraintTop_toBottomOf="@+id/text_event_title">

        <ImageButton
            android:id="@+id/btn_action_add"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_avatar_circle"
            android:contentDescription="Invite guests"
            android:src="@android:drawable/ic_input_add"
            app:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_action_qr"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_avatar_circle"
            android:contentDescription="Event QR code"
            android:src="@drawable/ic_qr_code"
            app:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_action_download"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_avatar_circle"
            android:src="@android:drawable/stat_sys_download"
            app:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_action_location"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_avatar_circle"
            android:src="@android:drawable/ic_dialog_map"
            app:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_action_chat"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_avatar_circle"
            android:src="@android:drawable/sym_action_chat"
            app:tint="#FFFFFF"
            />
    </LinearLayout>

    <GridLayout
        android:id="@+id/grid_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:columnCount="2"
        android:rowCount="2"
        android:useDefaultMargins="true"
        app:layout_constraintTop_toBottomOf="@+id/layout_action_buttons">

        <TextView
            android:id="@+id/tab_waiting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tab_inactive"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Waiting (42)"
            android:textColor="#5A5C69"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tab_chosen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tab_active"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Chosen (10) •"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tab_enrolled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tab_inactive"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Enrolled (8)"
            android:textColor="#5A5C69"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tab_cancelled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tab_inactive"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Cancelled (5)"
            android:textColor="#5A5C69"
            android:textSize="14sp" />
    </GridLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#F8F9FA"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@+id/layout_bottom_buttons"
        app:layout_constraintTop_toBottomOf="@+id/grid_tabs">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp">

            <TextView
                android:id="@+id/text_list_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chosen Entrants"
                android:textColor="#2B2D42"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/badge_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_avatar_inner"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="10 Total"
                android:textColor="#3F38DD"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="@+id/text_list_header"
                app:layout_constraintStart_toEndOf="@+id/text_list_header"
                app:layout_constraintTop_toTopOf="@+id/text_list_header" />

            <TextView
                android:id="@+id/text_empty_list"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:textColor="#7A7C87"
                android:textSize="15sp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/text_list_header" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_chosen_entrants"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/text_list_header"
                tools:listitem="@layout/item_chosen_entrant" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/layout_bottom_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_run_lottery"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Run Lottery"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="#3F38DD"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_rotate" />

            <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_notify"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Notify"
            android:textAllCaps="false"
            android:textColor="#3F38DD"
            android:textSize="16sp"
            app:backgroundTint="#E2DDF8"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_popup_reminder"
            app:iconTint="#3F38DD" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNotifyCancelled"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:text="Notify cancelled entrants"
            android:textAllCaps="false"
            android:textColor="#3D3D6B"
            android:textSize="13sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#5C6BC0"
            app:strokeWidth="1dp"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExportCsv"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="Export final roster (CSV)"
            android:textAllCaps="false"
            android:textColor="#3D3D6B"
            android:textSize="13sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#5C6BC0"
            app:strokeWidth="1dp"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelNonSignup"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="Cancel invited entrants who did not enroll"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            style="@style/Widget.MaterialComponents.Button"
            app:backgroundTint="#E57373"
            app:cornerRadius="24dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>