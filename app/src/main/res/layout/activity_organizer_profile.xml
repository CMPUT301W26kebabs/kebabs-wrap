<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F3FA">

    <!-- Purple header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/follow_button_bg"
        android:paddingTop="44dp"
        android:paddingBottom="32dp"
        android:paddingHorizontal="20dp">

        <ImageView
            android:id="@+id/btnBackProfile"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF"
            android:layout_alignParentStart="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/btnBackProfile"
            android:layout_marginTop="20dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAvatarLarge"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:gravity="center"
                android:background="@drawable/bg_avatar_large"
                android:textColor="@color/follow_button_bg"
                android:textSize="36sp"
                android:textStyle="bold"
                android:text="O" />

            <TextView
                android:id="@+id/tvOrganizerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Organizer"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFollowerCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_follower_count_badge"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="0 Followers"
                android:textColor="#E8E7FF"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnFollowProfile"
                android:layout_width="160dp"
                android:layout_height="44dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_avatar_large"
                android:text="@string/follow"
                android:textAllCaps="false"
                android:textColor="@color/follow_button_bg"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Events section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/active_events"
            android:textColor="#2E2C59"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNoEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:text="@string/no_active_events"
            android:textColor="#8A86A8"
            android:textSize="15sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvOrganizerEvents"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="12dp"
            android:clipToPadding="false" />
    </LinearLayout>
</LinearLayout>
