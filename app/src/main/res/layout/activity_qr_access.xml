<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Aurora animated background -->
    <com.example.eventmanager.ui.AuroraBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Soft vignette overlay for depth -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_splash_gradient_overlay" />

    <!-- Content layer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingBottom="44dp">

        <!-- Top spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="0.7" />

        <!-- Phone illustration with glow -->
        <FrameLayout
            android:id="@+id/qrIllustration"
            android:layout_width="240dp"
            android:layout_height="310dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Glow behind phone -->
            <View
                android:id="@+id/phoneGlow"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_qr_phone_glow" />

            <!-- Glass phone body -->
            <View
                android:layout_width="156dp"
                android:layout_height="240dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_qr_phone_glass"
                android:elevation="8dp" />

            <!-- Notch -->
            <View
                android:layout_width="48dp"
                android:layout_height="6dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_qr_notch_glass"
                android:elevation="9dp" />

            <!-- QR code screen -->
            <FrameLayout
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:layout_gravity="center"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_qr_screen_glass"
                android:elevation="9dp"
                android:padding="10dp">

                <!-- 7x7 realistic QR grid -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:columnCount="7"
                    android:rowCount="7">

                    <!-- Row 1: finder - dark - finder - light - finder - dark - finder -->
                    <View style="@style/QrPremiumFinder" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumFinder" />
                    <View style="@style/QrPremiumLight" />
                    <View style="@style/QrPremiumFinder" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumFinder" />

                    <!-- Row 2 -->
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumLight" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumLight" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumLight" />

                    <!-- Row 3 -->
                    <View style="@style/QrPremiumFinder" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumLight" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumLight" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumFinder" />

                    <!-- Row 4 -->
                    <View style="@style/QrPremiumLight" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumLight" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumLight" />

                    <!-- Row 5 -->
                    <View style="@style/QrPremiumFinder" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumLight" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumLight" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumFinder" />

                    <!-- Row 6 -->
                    <View style="@style/QrPremiumLight" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumLight" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumLight" />
                    <View style="@style/QrPremiumDark" />

                    <!-- Row 7 -->
                    <View style="@style/QrPremiumFinder" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumFinder" />
                    <View style="@style/QrPremiumLight" />
                    <View style="@style/QrPremiumFinder" />
                    <View style="@style/QrPremiumDark" />
                    <View style="@style/QrPremiumFinder" />
                </GridLayout>
            </FrameLayout>

            <!-- Scan frame with glow -->
            <View
                android:id="@+id/scanFrame"
                android:layout_width="128dp"
                android:layout_height="128dp"
                android:layout_gravity="center"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_qr_scan_corners"
                android:elevation="10dp" />

            <!-- Scan line (animated in Activity) -->
            <View
                android:id="@+id/scanLine"
                android:layout_width="100dp"
                android:layout_height="2dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="65dp"
                android:background="@color/brand_accent"
                android:elevation="11dp" />

            <!-- Home bar at bottom of phone -->
            <View
                android:layout_width="56dp"
                android:layout_height="4dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_qr_notch_glass"
                android:elevation="9dp" />
        </FrameLayout>

        <!-- Headline -->
        <TextView
            android:id="@+id/qrMessageText"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:gravity="center"
            android:letterSpacing="-0.02"
            android:lineSpacingExtra="4dp"
            android:text="@string/qr_message"
            android:textColor="@android:color/white"
            android:textSize="30sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/qrSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:letterSpacing="0.01"
            android:text="@string/qr_subtitle"
            android:textColor="@color/text_muted_lavender"
            android:textSize="15sp" />

        <!-- Bottom spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1.0" />

        <!-- Navigation bar: Skip / Dots / Next -->
        <LinearLayout
            android:id="@+id/navBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <TextView
                android:id="@+id/qrSkip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp"
                android:paddingEnd="16dp"
                android:text="@string/skip"
                android:textColor="@color/text_secondary_muted"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_dot_inactive_light" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_dot_inactive_light" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_dot_active_light" />
            </LinearLayout>

            <TextView
                android:id="@+id/qrNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp"
                android:paddingStart="16dp"
                android:text="@string/next"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
