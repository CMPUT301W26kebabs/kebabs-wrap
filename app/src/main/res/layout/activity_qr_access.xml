<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_lavender">

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-56dp"
        android:layout_marginTop="-20dp"
        android:background="@drawable/bg_outline_arch" />

    <View
        android:layout_width="190dp"
        android:layout_height="190dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-8dp"
        android:layout_marginEnd="-46dp"
        android:background="@drawable/bg_outline_arch" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="72dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <FrameLayout
            android:id="@+id/qrIllustration"
            android:layout_width="200dp"
            android:layout_height="240dp">

            <View
                android:layout_width="124dp"
                android:layout_height="188dp"
                android:layout_gravity="top|center_horizontal"
                android:background="@drawable/bg_qr_phone" />

            <View
                android:layout_width="84dp"
                android:layout_height="10dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_social_button" />

            <FrameLayout
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_qr_screen"
                android:padding="12dp">

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:columnCount="5"
                    android:rowCount="5">

                    <View style="@style/QrCellFinder" />
                    <View style="@style/QrCellDark" />
                    <View style="@style/QrCellFinder" />
                    <View style="@style/QrCellLight" />
                    <View style="@style/QrCellFinder" />
                    <View style="@style/QrCellDark" />
                    <View style="@style/QrCellLight" />
                    <View style="@style/QrCellDark" />
                    <View style="@style/QrCellDark" />
                    <View style="@style/QrCellLight" />
                    <View style="@style/QrCellFinder" />
                    <View style="@style/QrCellDark" />
                    <View style="@style/QrCellLight" />
                    <View style="@style/QrCellDark" />
                    <View style="@style/QrCellFinder" />
                    <View style="@style/QrCellLight" />
                    <View style="@style/QrCellDark" />
                    <View style="@style/QrCellDark" />
                    <View style="@style/QrCellLight" />
                    <View style="@style/QrCellDark" />
                    <View style="@style/QrCellFinder" />
                    <View style="@style/QrCellLight" />
                    <View style="@style/QrCellFinder" />
                    <View style="@style/QrCellDark" />
                    <View style="@style/QrCellFinder" />
                </GridLayout>
            </FrameLayout>

        </FrameLayout>

        <TextView
            android:id="@+id/qrMessageText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:text="@string/qr_message"
            android:textColor="@color/text_primary"
            android:textSize="29sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/qrSkip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/skip"
                android:textColor="@color/text_muted"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_dot_inactive" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_dot_inactive" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_dot_active" />
            </LinearLayout>

            <TextView
                android:id="@+id/qrNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/next"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
