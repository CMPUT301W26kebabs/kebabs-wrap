<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_run_lottery.xml
    Replaces your existing bare-bones layout.
    Uses drawables already in your project:
      - bg_lottery_header.xml
      - bg_illustration_circle.xml
      - ic_arrow_back.xml
      - ic_dice.xml
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FF">

    <!-- ══════════════════════════════════════════════
         BLUE CURVED HEADER  (uses your bg_lottery_header.xml)
         ══════════════════════════════════════════════ -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="@drawable/bg_lottery_header" />

    <!-- Back arrow + "Lottery Draw" title sit on top of the header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="16dp"
        android:orientation="vertical"
        android:paddingTop="52dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Lottery Draw"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════
         SCROLLABLE BODY  — sits below header
         ══════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingTop="155dp"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="48dp">

            <!-- ─────────────────────────────────────────
                 MAIN DRAW CARD
                 ───────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDraw"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="18dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="28dp">

                    <!-- Illustration + "Number of Winners" label -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Illustration circle — uses your bg_illustration_circle.xml -->
                        <FrameLayout
                            android:layout_width="96dp"
                            android:layout_height="96dp"
                            android:layout_marginEnd="16dp">

                            <View
                                android:layout_width="96dp"
                                android:layout_height="96dp"
                                android:background="@drawable/bg_illustration_circle" />

                            <!-- Dice icon from your existing drawable -->
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_dice"
                                android:contentDescription="Lottery dice"
                                app:tint="#5C6BC0" />

                            <!-- Decorative coloured dots -->
                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:layout_gravity="top|end"
                                android:layout_marginTop="6dp"
                                android:layout_marginEnd="2dp"
                                android:background="@drawable/dot_teal" />

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:layout_gravity="bottom|start"
                                android:layout_marginBottom="8dp"
                                android:background="@drawable/dot_red" />

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:layout_gravity="center_vertical|end"
                                android:background="@drawable/dot_green" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Number of Winners"
                            android:textColor="#1A1A2E"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>

                    <!-- Thin divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="20dp"
                        android:background="#EBEBF5" />

                    <!-- ── Counter row: [ − ]  10  [ + ] ── -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Minus -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDecrement"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            android:text="−"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            app:backgroundTint="#5C6BC0"
                            app:cornerRadius="26dp" />

                        <!-- Counter number -->
                        <TextView
                            android:id="@+id/tvWinnerCount"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="#1A1A2E"
                            android:textSize="50sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black" />

                        <!-- Plus -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnIncrement"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            android:text="+"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            app:backgroundTint="#5C6BC0"
                            app:cornerRadius="26dp" />

                    </LinearLayout>

                    <!-- "from X waiting entrants" -->
                    <TextView
                        android:id="@+id/tvWaitlistCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="loading waitlist…"
                        android:textColor="#8A8AA0"
                        android:textSize="13sp"
                        android:gravity="center" />

                    <!-- Progress indicator (hidden until draw starts) -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressBarDraw"
                        style="@style/Widget.MaterialComponents.LinearProgressIndicator"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:visibility="gone"
                        app:indicatorColor="#5C6BC0"
                        app:trackColor="#E8EAFF"
                        app:trackCornerRadius="4dp" />

                    <!-- Status / error message -->
                    <TextView
                        android:id="@+id/tvStatusMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <!-- DRAW WINNERS button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDrawWinners"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="18dp"
                        android:text="🎯  DRAW WINNERS"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.07"
                        app:backgroundTint="#5C6BC0"
                        app:cornerRadius="28dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ─────────────────────────────────────────
                 "Or draw replacement" divider row
                 ───────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="28dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#DDE0F0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Or draw replacement:"
                    android:textColor="#666688"
                    android:textSize="13sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#DDE0F0" />

            </LinearLayout>

            <!-- DRAW 1 REPLACEMENT outlined button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDrawReplacement"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:minWidth="220dp"
                android:text="DRAW 1 REPLACEMENT"
                android:textColor="#3D3D6B"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#5C6BC0"
                app:strokeWidth="2dp"
                app:cornerRadius="26dp" />

            <!-- Debug: seed waitlist with 10 test entrants -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSeedWaitlist"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:text="🧪 Seed waitlist (10 test users)"
                android:textColor="#8888AA"
                android:textSize="12sp" />

            <!-- ─────────────────────────────────────────
                 RESULTS CARD  (hidden until draw completes)
                 ───────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="28dp"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🏆  Selected Winners"
                            android:textColor="#1A1A2E"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <!-- Badge showing count -->
                        <TextView
                            android:id="@+id/tvResultCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_indigo"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Winner list -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvWinners"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
