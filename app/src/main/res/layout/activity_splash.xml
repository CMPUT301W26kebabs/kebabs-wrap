<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/splash_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0B2E">

    <!-- Animated grid background -->
    <com.example.eventmanager.ui.AnimatedGridView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Dark gradient overlay so content is readable -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_splash_gradient_overlay" />

    <!-- Content layer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingBottom="40dp">

        <!-- Top spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1.0" />

        <!-- Logo + text panel (keeps id for SplashActivity animations) -->
        <LinearLayout
            android:id="@+id/logo_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!-- Logo card with soft glow -->
            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:background="@drawable/bg_splash_logo_glow"
                android:padding="16dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/splash_logo_content_description"
                    android:scaleType="fitCenter"
                    android:src="@drawable/spotly_logo" />
            </FrameLayout>

            <!-- App name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:letterSpacing="0.08"
                android:text="SPOTLY"
                android:textColor="@android:color/white"
                android:textSize="36sp"
                android:textStyle="bold" />

            <!-- Tagline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:letterSpacing="0.04"
                android:text="Fair draw for every event."
                android:textColor="#B8B3FF"
                android:textSize="15sp" />

            <!-- Status text (existing id) -->
            <TextView
                android:id="@+id/tv_checking_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:text="@string/splash_checking_device"
                android:textColor="#9E97E0"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Bottom spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1.2" />

        <!-- Bottom actions (keeps existing ids) -->
        <LinearLayout
            android:id="@+id/bottom_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_get_started"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="@string/splash_get_started"
                android:textAllCaps="false"
                android:textColor="#0D0B2E"
                android:textSize="17sp"
                android:textStyle="bold"
                app:backgroundTint="@android:color/white"
                app:cornerRadius="29dp"
                app:strokeWidth="0dp" />

            <LinearLayout
                android:id="@+id/login_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/already_have_account"
                    android:textColor="#A09ABF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/btn_log_in"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:text="@string/log_in_link"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
