<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Top AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <!-- Back arrow -->
            <ImageButton
                android:id="@+id/btnBackAdmin"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@drawable/outline_arrow_back_24"
                android:contentDescription="Back"
                app:tint="#1A1A2E" />

            <!-- Title: Events -->
            <TextView
                android:id="@+id/tvAdminEventsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Events"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>

            <!-- ADMIN badge -->
            <TextView
                android:id="@+id/tvAdminBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:text="ADMIN"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_badge_admin_green"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>

        </androidx.appcompat.widget.Toolbar>

        <!-- Search Bar -->
        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchViewEvents"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_search_rounded"
            app:queryHint="Search events..."
            app:iconifiedByDefault="false"
            app:searchIcon="@drawable/outline_search_24"
            app:queryBackground="@android:color/transparent"/>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/progressBarAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="48dp"
            android:visibility="gone"
            tools:visibility="gone"/>

        <LinearLayout
            android:id="@+id/layoutEmptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="64dp"
            android:visibility="gone"
            tools:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/outline_event_busy_24"
                android:contentDescription="No events"
                android:alpha="0.4"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No events found"
                android:textSize="16sp"
                android:textColor="#888888"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutErrorState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="64dp"
            android:visibility="gone"
            tools:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/outline_error_24"
                android:contentDescription="Error"
                android:alpha="0.5"/>

            <TextView
                android:id="@+id/tvErrorMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Failed to load events. Please try again."
                android:textSize="14sp"
                android:textColor="#888888"
                android:layout_marginTop="8dp"
                android:gravity="center"/>

            <Button
                android:id="@+id/btnRetryAdmin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Retry"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_purple_rounded"/>
        </LinearLayout>

        <!-- Events RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAdminEvents"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_admin_event"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>