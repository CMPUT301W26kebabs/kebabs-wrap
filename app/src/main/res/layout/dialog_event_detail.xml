<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="32dp">

    <View android:layout_width="40dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal" android:layout_marginTop="12dp"
        android:background="@drawable/bg_drag_handle" />

    <ImageView android:id="@+id/iv_event_poster"
        android:layout_width="match_parent" android:layout_height="180dp"
        android:layout_marginTop="16dp" android:layout_marginHorizontal="20dp"
        android:scaleType="centerCrop" android:visibility="gone"
        android:background="@drawable/bg_poster_rounded" />

    <TextView android:id="@+id/tv_event_name"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="20dp" android:paddingHorizontal="24dp"
        android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" />

    <LinearLayout android:id="@+id/status_badge"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="8dp" android:layout_marginStart="24dp"
        android:paddingHorizontal="12dp" android:paddingVertical="4dp"
        android:background="@drawable/bg_chip_active">
        <TextView android:id="@+id/tv_status"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#FFFFFF" android:textSize="11sp"
            android:textStyle="bold" android:letterSpacing="0.08" />
    </LinearLayout>

    <TextView android:id="@+id/tv_event_id"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:paddingHorizontal="24dp"
        android:textColor="#6B7280" android:textSize="12sp" android:fontFamily="monospace" />

    <TextView android:id="@+id/tv_event_description"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="16dp" android:paddingHorizontal="24dp"
        android:textColor="#A0A4B8" android:textSize="14sp" android:lineSpacingMultiplier="1.4" />

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginVertical="20dp" android:layout_marginHorizontal="24dp"
        android:background="#2A2D3A" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="24dp">

        <TextView android:id="@+id/tv_organizer_id"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_person_small" android:drawablePadding="10dp"
            android:textColor="#8B8FA3" android:textSize="13sp" android:layout_marginBottom="10dp" />
        <TextView android:id="@+id/tv_capacity"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_people_small" android:drawablePadding="10dp"
            android:textColor="#8B8FA3" android:textSize="13sp" android:layout_marginBottom="10dp" />
        <TextView android:id="@+id/tv_waitlist_cap"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_list_small" android:drawablePadding="10dp"
            android:textColor="#8B8FA3" android:textSize="13sp" android:layout_marginBottom="10dp" />
        <TextView android:id="@+id/tv_reg_start"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_clock_small" android:drawablePadding="10dp"
            android:textColor="#8B8FA3" android:textSize="13sp" android:layout_marginBottom="10dp" />
        <TextView android:id="@+id/tv_reg_end"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_clock_small" android:drawablePadding="10dp"
            android:textColor="#8B8FA3" android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingHorizontal="24dp"
        android:layout_marginTop="24dp" android:gravity="end">
        <Button android:id="@+id/btn_restore_event"
            android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="Restore Event" android:textColor="#22C55E" android:textAllCaps="false"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/bg_button_restore" android:paddingHorizontal="24dp"
            android:visibility="gone" />
        <Button android:id="@+id/btn_remove_event"
            android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="Remove Event" android:textColor="#FFFFFF" android:textAllCaps="false"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/bg_button_danger" android:paddingHorizontal="24dp" />
    </LinearLayout>
</LinearLayout>
