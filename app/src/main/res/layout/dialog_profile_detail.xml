<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/bg_bottom_sheet" android:paddingBottom="32dp">

    <View android:layout_width="40dp" android:layout_height="4dp" android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp" android:background="@drawable/bg_drag_handle" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"
        android:gravity="center_horizontal" android:paddingTop="24dp" android:paddingBottom="8dp">
        <FrameLayout android:layout_width="72dp" android:layout_height="72dp">
            <View android:layout_width="72dp" android:layout_height="72dp" android:background="@drawable/bg_avatar_circle_large" />
            <TextView android:id="@+id/tv_avatar_initials" android:layout_width="match_parent" android:layout_height="match_parent"
                android:gravity="center" android:textColor="#FFFFFF" android:textSize="28sp" android:textStyle="bold" />
        </FrameLayout>
        <TextView android:id="@+id/tv_profile_name" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="14dp" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" />
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal"
            android:layout_marginTop="8dp" android:gravity="center">
            <TextView android:id="@+id/tv_role_badge" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:background="@drawable/bg_chip" android:paddingHorizontal="12dp" android:paddingVertical="4dp"
                android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.08" android:visibility="gone" />
            <LinearLayout android:id="@+id/status_badge" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="8dp" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:background="@drawable/bg_chip_active">
                <TextView android:id="@+id/tv_status" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.08" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="20dp"
        android:layout_marginHorizontal="24dp" android:background="#2A2D3A" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="24dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EMAIL"
                android:textColor="#6B7280" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.1" />
            <TextView android:id="@+id/tv_profile_email" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:textColor="#FFFFFF" android:textSize="15sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PHONE"
                android:textColor="#6B7280" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.1" />
            <TextView android:id="@+id/tv_profile_phone" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:textColor="#FFFFFF" android:textSize="15sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DEVICE ID"
                android:textColor="#6B7280" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.1" />
            <TextView android:id="@+id/tv_device_id" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:textColor="#A0A4B8" android:textSize="13sp" android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"
        android:paddingHorizontal="24dp" android:layout_marginTop="8dp" android:gravity="end">
        <Button android:id="@+id/btn_promote_admin" android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="@string/admin_promote_button" android:textColor="@color/brand_accent" android:textAllCaps="false" android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/bg_chip_unselected" android:paddingHorizontal="24dp" android:layout_marginEnd="8dp" android:visibility="gone" />
        <Button android:id="@+id/btn_restore_profile" android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="Restore Profile" android:textColor="#22C55E" android:textAllCaps="false" android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/bg_button_restore" android:paddingHorizontal="24dp" android:visibility="gone" />
        <Button android:id="@+id/btn_disable_profile" android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="@string/admin_delete_profile_button" android:textColor="#FFFFFF" android:textAllCaps="false" android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/bg_button_danger" android:paddingHorizontal="24dp" />
    </LinearLayout>
</LinearLayout>
