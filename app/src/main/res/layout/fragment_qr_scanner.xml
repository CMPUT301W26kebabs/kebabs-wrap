<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:id="@+id/layoutScannerTopBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Scan"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"/>
    </LinearLayout>

    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreviewView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutScannerTopBar"
        app:layout_constraintBottom_toTopOf="@id/layoutScannerBottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <FrameLayout
        android:id="@+id/layoutScanFrame"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_qr_scan_frame"
        app:layout_constraintTop_toBottomOf="@id/layoutScannerTopBar"
        app:layout_constraintBottom_toTopOf="@id/layoutScannerBottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvScanHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Point camera at an event QR code"
        android:textSize="14sp"
        android:textColor="@android:color/white"
        android:background="#99000000"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/layoutScannerBottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:id="@+id/layoutScannerBottomBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#000000"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnOpenGallery"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/outline_photo_library_24"
            android:background="@android:color/transparent"
            android:contentDescription="Open gallery to scan QR"
            app:tint="#AAAAAA" />

        <ImageButton
            android:id="@+id/btnScanQR"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:src="@drawable/outline_lock_open_24"
            android:background="@drawable/bg_circle_white"
            android:contentDescription="Scan QR code"
            app:tint="#1A1A2E" />

        <!-- Settings icon -->
        <ImageButton
            android:id="@+id/btnScannerSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/outline_settings_24"
            android:background="@android:color/transparent"
            android:contentDescription="Scanner settings"
            app:tint="#AAAAAA" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvBottomLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ENTRANTUS 01.06.01\nQR Scanner"
        android:textSize="11sp"
        android:textColor="#666666"
        android:gravity="center"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/layoutScanResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:visibility="gone"
        tools:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/layoutScannerBottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvScanResultTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Event Found!"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"/>

        <TextView
            android:id="@+id/tvScanResultDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="World's Largest Tech Expo"
            android:textSize="14sp"
            android:textColor="#CCCCCC"
            android:layout_marginTop="6dp"/>

        <Button
            android:id="@+id/btnJoinFromScan"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Join Waiting List"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_button_gradient_purple"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginTop="16dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>