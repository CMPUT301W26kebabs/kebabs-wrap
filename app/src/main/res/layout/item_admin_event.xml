<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:background="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- Event name -->
        <TextView
            android:id="@+id/tvAdminEventName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            tools:text="Tech Meetup"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnRemoveEvent"/>

        <!-- Event date -->
        <TextView
            android:id="@+id/tvAdminEventDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            tools:text="Mar 15"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginTop="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvAdminEventName"
            app:layout_constraintEnd_toStartOf="@id/btnRemoveEvent"/>

        <!-- Remove button (soft delete - audit info preserved) -->
        <!-- Red pill button, only visible to admins -->
        <Button
            android:id="@+id/btnRemoveEvent"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="REMOVE"
            android:textSize="11sp"
            android:textColor="@android:color/white"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_button_red_pill"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>