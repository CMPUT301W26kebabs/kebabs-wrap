<?xml version="1.0" encoding="utf-8"?>
<!-- item_attendee.xml — used by RecyclerView in activity_manage_event.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Section Header (e.g. "A", "B") — GONE when not the first item of a letter group -->
    <TextView
        android:id="@+id/tvSectionHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/poppins_bold"
        android:textColor="#4B4BDB"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="visible"
        tools:text="A" />

    <!-- Attendee Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="0dp"
        android:paddingEnd="0dp">

        <!-- Avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/ivAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_person_placeholder"
            app:civ_border_color="#EEEEEE"
            app:civ_border_width="1dp"
            android:contentDescription="Attendee avatar" />

        <!-- Name -->
        <TextView
            android:id="@+id/tvAttendeeName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/poppins_regular"
            android:textColor="#222222"
            android:textSize="15sp"
            tools:text="Alex Jim" />

    </LinearLayout>

    <!-- Thin Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="64dp"
        android:background="#EEEEEE" />

</LinearLayout>