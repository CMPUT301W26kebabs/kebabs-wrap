<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="24dp">

    <ImageView
        android:id="@+id/image_comment_avatar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_icon_circle_light"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_comment_author"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:text="Author Name"
        android:textColor="#2B2D42"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/btn_delete_comment"
        app:layout_constraintStart_toEndOf="@+id/image_comment_avatar"
        app:layout_constraintTop_toTopOf="@+id/image_comment_avatar" />

    <TextView
        android:id="@+id/text_comment_time"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:text="2 hours ago"
        android:textColor="#A0A3BD"
        android:textSize="12sp"
        app:layout_constraintEnd_toStartOf="@+id/btn_delete_comment"
        app:layout_constraintStart_toEndOf="@+id/image_comment_avatar"
        app:layout_constraintTop_toBottomOf="@+id/text_comment_author" />

    <ImageButton
        android:id="@+id/btn_delete_comment"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_light_red"
        android:src="@android:drawable/ic_menu_delete"
        app:tint="#D32F2F"
        app:layout_constraintBottom_toBottomOf="@+id/text_comment_time"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/text_comment_author" />

    <TextView
        android:id="@+id/text_comment_body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:text="This is a placeholder for the actual comment text that the user submitted."
        android:textColor="#4A4C59"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/image_comment_avatar"
        app:layout_constraintTop_toBottomOf="@+id/text_comment_time" />

</androidx.constraintlayout.widget.ConstraintLayout>