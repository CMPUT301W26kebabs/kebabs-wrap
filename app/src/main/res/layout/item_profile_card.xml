<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/card_root" android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp"
    android:paddingHorizontal="24dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">

    <FrameLayout android:layout_width="48dp" android:layout_height="48dp">
        <View android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_avatar_circle" />
        <TextView android:id="@+id/tv_avatar_initials" android:layout_width="match_parent" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
    </FrameLayout>

    <TextView android:id="@+id/tv_profile_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
        android:paddingStart="16dp" android:paddingEnd="12dp" android:textColor="#000000" android:textSize="15sp" android:textStyle="bold"
        android:maxLines="1" android:ellipsize="end" />

    <TextView android:id="@+id/btn_remove" android:layout_width="wrap_content" android:layout_height="32dp" android:gravity="center"
        android:text="REMOVE" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold"
        android:background="@drawable/bg_pill_red" android:paddingHorizontal="16dp" />

    <TextView android:id="@+id/btn_done" android:layout_width="wrap_content" android:layout_height="32dp" android:gravity="center"
        android:text="Done" android:textColor="#6B7280" android:textSize="12sp" android:textStyle="bold"
        android:background="@drawable/bg_pill_gray_outline" android:paddingHorizontal="20dp" android:visibility="gone" />
</LinearLayout>
