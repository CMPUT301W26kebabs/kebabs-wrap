<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="24dp" android:gravity="center">
    <TextView android:id="@+id/tvInvitationEventName" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="22sp" android:textStyle="bold" android:textColor="#000000" android:gravity="center" />
    <TextView android:id="@+id/tvInvitationStatus" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="14sp" android:textColor="#6B7280" android:gravity="center" android:layout_marginTop="12dp" />
    <Button android:id="@+id/btnAcceptInvitation" android:layout_width="match_parent" android:layout_height="52dp"
        android:text="Accept" android:backgroundTint="#4A43EC" android:textColor="#FFFFFF" android:layout_marginTop="32dp" />
    <Button android:id="@+id/btnDeclineInvitation" android:layout_width="match_parent" android:layout_height="52dp"
        android:text="Decline" android:backgroundTint="#FF445D" android:textColor="#FFFFFF" android:layout_marginTop="12dp" />
</LinearLayout>
