<resources>
    <style name="CalendarDayHeader">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="CalendarDayValue">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="CalendarDayValueBold">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="QrCellBase">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
    </style>

    <style name="QrCellDark" parent="QrCellBase">
        <item name="android:background">@color/text_primary</item>
    </style>

    <style name="QrCellLight" parent="QrCellBase">
        <item name="android:background">@color/white</item>
    </style>

    <style name="QrCellFinder" parent="QrCellBase">
        <item name="android:background">@drawable/bg_qr_finder</item>
    </style>

    <style name="QrCellDarkBrand" parent="QrCellBase">
        <item name="android:background">@color/brand_accent</item>
    </style>

    <style name="QrCellFinderBrand" parent="QrCellBase">
        <item name="android:background">@drawable/bg_qr_finder_brand</item>
    </style>

    <!-- Premium rounded variants for the redesigned QR page -->
    <style name="QrPremiumDark" parent="QrCellBase">
        <item name="android:background">@drawable/bg_qr_cell_brand_rounded</item>
    </style>

    <style name="QrPremiumLight" parent="QrCellBase">
        <item name="android:background">@drawable/bg_qr_cell_light_rounded</item>
    </style>

    <style name="QrPremiumFinder" parent="QrCellBase">
        <item name="android:background">@drawable/bg_qr_finder_brand_rounded</item>
    </style>
</resources>
